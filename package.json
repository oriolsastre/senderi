{
  "name": "excursions",
  "version": "1.0.0",
  "description": "Gestionar les meves excursions",
  "type": "module",
  "scripts": {
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start:client:dev": "vite",
    "start:server:dev": "tsx watch server/index.ts",
    "start:dev": "concurrently -k -n server,vite \"npm run start:server:dev\" \"npm run start:client:dev\"",
    "dev": "concurrently -k -n server,vite \"npm run start:server:dev\" \"npm run start:client:dev\"",
    "start": "node server/dist/index.js",
    "db:init": "node database/init-db.js",
    "db:seed": "node database/seed.js"
  },
  "keywords": [
    "vite",
    "express",
    "excursions",
    "gpx"
  ],
  "author": "Oriol Sastre",
  "license": "ISC",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "leaflet-gpx": "^2.2.0",
    "proj4leaflet": "^1.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  }
}